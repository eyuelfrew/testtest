PORT=3030
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=teftef_admin_db

# JWT Configuration (MUST MATCH BACKEND!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ADMIN_EXPIRES_IN=1d
JWT_ADMIN_COOKIE_DAYS=1

# CORS
ADMIN_SERVICE_URL=http://localhost:3030
BACKEND_SERVICE_URL=http://localhost:5000
CLIENT_ORIGIN=http://localhost:5173

# For production deployment, update to:
# ADMIN_SERVICE_URL=https://teftef-admin-service.virallinkdigital.com
